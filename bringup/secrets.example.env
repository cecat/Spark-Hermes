# Template for ~/.hermes/.env — copy, fill in real values, chmod 600.
# This file lives at ~/.hermes/.env on the host. It is NOT in the git repo.
#
# How to get each value: see bringup/20-slack-app/README.md.

# Slack bot user OAuth token (xoxb-…). From OAuth & Permissions page after
# installing the app to your workspace.
SLACK_BOT_TOKEN=xoxb-REPLACE_ME

# Slack app-level token (xapp-…) with connections:write scope. From
# Basic Information → App-Level Tokens. Shown only once at creation.
SLACK_APP_TOKEN=xapp-REPLACE_ME

# Your Slack member ID (U…). Profile → ⋮ → Copy member ID.
# Hermes denies all DMs/mentions from users not on this comma-separated list.
SLACK_ALLOWED_USERS=U_REPLACE_ME

# Gandalf's home Slack channel ID (C…). About panel of the channel in Slack.
# Cron jobs default to delivering here.
SLACK_HOME_CHANNEL=C_REPLACE_ME

# Channels Hermes is allowed to participate in (besides DMs). Comma-separated
# list of channel IDs. Typically same as SLACK_HOME_CHANNEL for single-channel
# use; add others as Gandalf takes on more duties.
SLACK_ALLOWED_CHANNELS=C_REPLACE_ME
